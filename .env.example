# ─── Banco (Postgres no MiniDeskServer via Docker) ─────────────
DATABASE_URL="postgresql://loja:loja3d_dev@192.168.50.92:5432/loja3d?sslmode=disable"

# ─── Auth.js ───────────────────────────────────────────────────
# Gere com: npx auth secret
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Rodando o app fora de localhost, defina a URL base:
# AUTH_URL="http://192.168.50.92:3000"
# AUTH_TRUST_HOST=true

# ─── Storage S3-compatível (MinIO no MiniDeskServer, dev) ──────
S3_ENDPOINT="http://192.168.50.92:9000"
S3_FORCE_PATH_STYLE="true"
S3_ACCESS_KEY_ID="loja3d"
S3_SECRET_ACCESS_KEY="loja3d_dev_secret"
S3_BUCKET="loja3d"
S3_PUBLIC_URL="http://192.168.50.92:9000/loja3d"

# Em produção (R2): S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com,
# S3_FORCE_PATH_STYLE=false, S3_PUBLIC_URL=https://cdn.seudominio.dev

# ─── Plataforma / seed ─────────────────────────────────────────
PLATFORM_ADMIN_EMAILS="voce@email.com"
SEED_ADMIN_EMAIL="voce@email.com"
